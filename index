<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>АкадемРабота — Академический рынок труда России</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#1A3157;
  --navy-dark:#0F1F38;
  --navy-mid:#1E3A6E;
  --gold:#C9973A;
  --gold-light:#E4B455;
  --cream:#F8F6F1;
  --light:#EFF3F8;
  --white:#FFFFFF;
  --text:#1A2B3C;
  --muted:#6B7A8D;
  --border:#DDE4EE;
}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;color:var(--text);background:var(--white);overflow-x:hidden}
.container{max-width:1100px;margin:0 auto;padding:0 28px}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  background:rgba(15,31,56,.97);
  backdrop-filter:blur(16px);
  border-bottom:1px solid rgba(201,151,58,.15);
  height:62px;display:flex;align-items:center;padding:0 36px;
  justify-content:space-between;
}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.nav-logo-mark{
  width:36px;height:36px;background:var(--gold);border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:#fff;
  position:relative;
}
.nav-logo-mark::after{
  content:'✦';position:absolute;top:-5px;right:-5px;
  font-size:8px;color:var(--gold);background:var(--navy-dark);
  width:12px;height:12px;display:flex;align-items:center;justify-content:center;
  border-radius:50%;
}
.nav-logo-text{font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:700;color:#fff}
.nav-logo-text span{color:var(--gold)}
.nav-sub{font-size:10px;color:rgba(255,255,255,.4);letter-spacing:.06em;margin-top:1px}
.nav-links{display:flex;gap:32px;list-style:none}
.nav-links a{font-size:13px;color:rgba(255,255,255,.65);text-decoration:none;transition:color .2s;font-weight:400}
.nav-links a:hover{color:var(--gold)}
.nav-cta{
  background:var(--gold);color:#fff;border:none;border-radius:7px;
  padding:9px 20px;font-size:13px;font-weight:600;cursor:pointer;
  text-decoration:none;transition:opacity .2s;letter-spacing:.02em;
}
.nav-cta:hover{opacity:.85}

/* ── HERO ── */
.hero{
  min-height:100vh;
  background:linear-gradient(160deg,#0F1F38 0%,#1A3157 55%,#1E3A6E 100%);
  position:relative;overflow:hidden;
  display:flex;align-items:center;
  padding:100px 0 60px;
}
/* Subtle arch watermark */
.hero-watermark{
  position:absolute;right:-80px;top:50%;transform:translateY(-50%);
  width:520px;height:520px;opacity:.04;
  border:60px solid #fff;border-radius:50% 50% 0 0/60% 60% 0 0;
}
.hero-dot1{position:absolute;top:15%;left:5%;width:180px;height:180px;border-radius:50%;border:25px solid rgba(201,151,58,.07)}
.hero-dot2{position:absolute;bottom:10%;right:10%;width:120px;height:120px;border-radius:50%;border:20px solid rgba(201,151,58,.05)}

.hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;position:relative;z-index:1}

/* Hero left */
.hero-tag{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(201,151,58,.12);border:1px solid rgba(201,151,58,.25);
  border-radius:20px;padding:5px 14px;margin-bottom:22px;
  font-size:11px;color:var(--gold);letter-spacing:.12em;text-transform:uppercase;font-weight:600;
}
.hero-tag-dot{width:5px;height:5px;border-radius:50%;background:var(--gold)}
.hero h1{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(40px,5vw,58px);font-weight:700;
  color:#fff;line-height:1.08;margin-bottom:18px;
}
.hero h1 span{color:var(--gold)}
.hero-desc{font-size:15px;color:rgba(255,255,255,.6);line-height:1.7;margin-bottom:30px;max-width:420px}
.hero-buttons{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:36px}
.btn-gold{
  background:var(--gold);color:#fff;border:none;border-radius:8px;
  padding:14px 28px;font-size:14px;font-weight:600;cursor:pointer;
  text-decoration:none;display:inline-flex;align-items:center;gap:8px;
  transition:transform .2s,box-shadow .2s;
}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(201,151,58,.4)}
.btn-outline{
  background:transparent;color:var(--gold);
  border:1.5px solid var(--gold);
  border-radius:8px;padding:13px 28px;font-size:14px;font-weight:600;
  cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:8px;
  transition:background .2s,color .2s;
}
.btn-outline:hover{background:rgba(201,151,58,.1)}

/* Hero mini features */
.hero-features{display:flex;flex-direction:column;gap:14px}
.hero-feat{display:flex;align-items:center;gap:12px}
.hero-feat-icon{
  width:40px;height:40px;border-radius:10px;
  border:1px solid rgba(255,255,255,.12);
  background:rgba(255,255,255,.05);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.hero-feat-icon svg{width:18px;height:18px}
.hero-feat-text{font-size:14px;color:rgba(255,255,255,.75);font-weight:400}

/* Hero right — mock UI */
.hero-visual{position:relative}

/* Laptop frame */
.laptop{
  background:#1a1a2e;border-radius:14px;padding:8px;
  box-shadow:0 40px 80px rgba(0,0,0,.5),0 0 0 1px rgba(255,255,255,.08);
  position:relative;
}
.laptop-screen{
  background:#fff;border-radius:8px;overflow:hidden;
  font-family:'Inter',sans-serif;
}
.laptop-bar{
  background:#F2F4F7;padding:8px 12px;
  display:flex;align-items:center;gap:10px;
  border-bottom:1px solid #E5E9F0;
}
.laptop-dots{display:flex;gap:5px}
.laptop-dot{width:8px;height:8px;border-radius:50%}
.laptop-nav-inner{
  display:flex;align-items:center;justify-content:space-between;
  flex:1;margin-left:8px;
}
.laptop-logo-s{font-family:'Cormorant Garamond',serif;font-size:12px;font-weight:700;color:var(--navy)}
.laptop-logo-s span{color:var(--gold)}
.laptop-nav-links{display:flex;gap:12px}
.laptop-nav-links span{font-size:9px;color:var(--muted);cursor:pointer}
.laptop-body{display:grid;grid-template-columns:1fr 1fr;min-height:200px}
/* Profile side */
.lpanel{padding:12px;border-right:1px solid #F0F2F5}
.lpanel-title{font-size:8px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px}
.lprofile{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.lavatar{
  width:32px;height:32px;border-radius:50%;
  background:linear-gradient(135deg,#C9973A,#8B6520);
  display:flex;align-items:center;justify-content:center;
  font-size:13px;font-weight:700;color:#fff;flex-shrink:0;
  font-family:'Cormorant Garamond',serif;
}
.lname{font-size:10px;font-weight:600;color:var(--navy)}
.lpos{font-size:8px;color:var(--muted);margin-top:1px}
.lmetrics{display:grid;grid-template-columns:repeat(3,1fr);gap:4px;margin-bottom:8px}
.lmetric{text-align:center;padding:5px 3px;background:#F8F9FC;border-radius:5px}
.lmetric-val{font-size:12px;font-weight:700;color:var(--navy);display:block}
.lmetric-label{font-size:7px;color:var(--muted)}
.lorcid{display:flex;align-items:center;gap:4px;margin-bottom:6px}
.lorcid-dot{width:8px;height:8px;border-radius:50%;background:#A6CE39;flex-shrink:0}
.lorcid-text{font-size:7.5px;color:var(--muted)}
.lstatus{
  background:#E8F5E9;border-radius:12px;padding:3px 9px;
  font-size:7.5px;color:#2E7D32;font-weight:500;display:inline-block;
}
/* Vacancy side */
.rpanel{padding:12px}
.rpanel-title{font-size:8px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px}
.rvac{border:1px solid #EEF0F5;border-radius:8px;padding:9px}
.rvac-org{display:flex;align-items:center;gap:5px;margin-bottom:4px}
.rvac-org-logo{
  width:16px;height:16px;border-radius:4px;
  background:var(--navy);display:flex;align-items:center;justify-content:center;
  font-size:6px;color:#fff;font-weight:700;flex-shrink:0;
}
.rvac-org-name{font-size:8px;color:var(--muted)}
.rvac-title{font-size:11px;font-weight:700;color:var(--navy);margin-bottom:5px}
.rvac-list{list-style:none}
.rvac-list li{font-size:7.5px;color:var(--muted);padding:1px 0;display:flex;align-items:center;gap:4px}
.rvac-list li::before{content:'•';color:var(--gold)}
.rvac-tags{display:flex;gap:4px;flex-wrap:wrap;margin-top:6px}
.rvac-tag{
  font-size:7px;padding:2px 7px;border-radius:10px;
  background:#F0F2F8;color:var(--muted);
}
.rvac-btn{
  display:block;margin-top:7px;width:100%;
  background:var(--navy);color:#fff;border:none;border-radius:5px;
  padding:5px;font-size:8px;font-weight:600;cursor:pointer;text-align:center;
}

/* Phone floating */
.phone-float{
  display:none;
  position:absolute;bottom:-20px;left:-30px;
  width:140px;
  background:#fff;border-radius:16px;
  box-shadow:0 20px 50px rgba(0,0,0,.35),0 0 0 1px rgba(0,0,0,.1);
  overflow:hidden;
  animation:floatPhone 4s ease-in-out infinite;
}
@keyframes floatPhone{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.phone-header{
  background:var(--navy);padding:8px 10px;
  display:flex;align-items:center;justify-content:space-between;
}
.phone-header-text{font-size:8px;font-weight:600;color:#fff}
.phone-header-dots{display:flex;gap:3px}
.phone-header-dot{width:4px;height:4px;border-radius:50%;background:rgba(255,255,255,.3)}
.phone-body{padding:10px}
.phone-score-wrap{display:flex;align-items:center;justify-content:center;margin-bottom:8px}
.phone-score-circle{
  width:56px;height:56px;border-radius:50%;
  background:conic-gradient(var(--gold) 0deg 331deg,#EEF0F5 331deg 360deg);
  display:flex;align-items:center;justify-content:center;
  position:relative;
}
.phone-score-inner{
  width:44px;height:44px;border-radius:50%;background:#fff;
  display:flex;align-items:center;justify-content:center;
  font-size:14px;font-weight:700;color:var(--navy);
  font-family:'Cormorant Garamond',serif;
}
.phone-name{font-size:9px;font-weight:600;color:var(--navy);text-align:center;margin-bottom:1px}
.phone-role{font-size:7.5px;color:var(--muted);text-align:center;margin-bottom:8px}
.phone-bars{display:flex;flex-direction:column;gap:4px;margin-bottom:8px}
.phone-bar-row{display:flex;align-items:center;justify-content:space-between;gap:6px}
.phone-bar-label{font-size:7px;color:var(--muted);white-space:nowrap;min-width:80px}
.phone-bar-track{flex:1;height:3px;background:#F0F2F5;border-radius:2px}
.phone-bar-fill{height:100%;border-radius:2px;background:var(--gold)}
.phone-bar-val{font-size:7px;font-weight:600;color:var(--navy);min-width:22px;text-align:right}
.phone-btn{
  display:block;width:100%;background:var(--navy);color:#fff;
  border:none;border-radius:6px;padding:6px;
  font-size:8px;font-weight:600;cursor:pointer;text-align:center;margin-bottom:4px;
}
.phone-btn-out{
  display:block;width:100%;background:transparent;color:var(--muted);
  border:1px solid #E5E9F0;border-radius:6px;padding:5px;
  font-size:8px;cursor:pointer;text-align:center;
}

/* ── SECTIONS ── */
section{padding:90px 0}
.section-alt{background:var(--cream)}
.section-dark{background:var(--navy)}

.section-label{
  font-size:11px;font-weight:600;color:var(--gold);
  letter-spacing:.14em;text-transform:uppercase;margin-bottom:10px;
}
.section-label-light{color:rgba(201,151,58,.8)}
.gold-underline{width:40px;height:2.5px;background:var(--gold);border-radius:2px;margin:10px 0 20px}
h2{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(28px,4vw,42px);font-weight:700;
  color:var(--navy);line-height:1.12;
}
h2.light{color:#fff}
.section-lead{font-size:16px;color:var(--muted);line-height:1.7;max-width:560px;margin-top:12px}
.section-lead.light{color:rgba(255,255,255,.6)}

/* ── WHY SECTION (страница 3) ── */
.why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;margin-top:48px}
.why-card{text-align:center}
.why-icon-wrap{
  width:72px;height:72px;border-radius:50%;background:#F0F3F8;
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 16px;
}
.why-icon-wrap svg{width:32px;height:32px}
.why-title{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:700;color:var(--navy);margin-bottom:6px}
.why-gold-line{width:28px;height:2px;background:var(--gold);margin:6px auto 10px}
.why-text{font-size:14px;color:var(--muted);line-height:1.6}

/* Quote */
.quote-block{
  margin-top:44px;
  border:1px solid #E8DCC8;border-left:4px solid var(--gold);
  border-radius:0 10px 10px 0;
  padding:28px 32px;background:rgba(201,151,58,.03);
  position:relative;
}
.quote-mark{
  font-family:'Cormorant Garamond',serif;font-size:80px;
  color:var(--gold);opacity:.25;line-height:1;
  position:absolute;top:-16px;left:20px;
}
.quote-text{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(18px,2.5vw,24px);font-style:italic;
  color:var(--navy);line-height:1.5;position:relative;
}

/* Stats strip */
.stats-strip{
  margin-top:44px;background:var(--navy);border-radius:14px;
  padding:32px 40px;
}
.stats-strip-title{
  text-align:center;font-family:'Cormorant Garamond',serif;
  font-size:20px;color:#fff;font-weight:600;margin-bottom:6px;
}
.stats-strip-line{width:32px;height:2px;background:var(--gold);margin:0 auto 28px}
.stats-row{display:grid;grid-template-columns:1fr 1px 1fr 1px 1fr;gap:0}
.stat-divider-v{background:rgba(255,255,255,.1)}
.stat-item{padding:0 32px;text-align:center}
.stat-num{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(40px,5vw,60px);font-weight:700;color:var(--gold);
  display:block;line-height:1;margin-bottom:8px;
}
.stat-title{font-size:14px;color:#fff;font-weight:500;margin-bottom:6px}
.stat-line{width:24px;height:1.5px;background:var(--gold);margin:6px auto}
.stat-sub{font-size:12px;color:rgba(255,255,255,.45);line-height:1.5}
.stats-footer{
  margin-top:20px;border:1px solid rgba(201,151,58,.3);border-radius:8px;
  padding:12px 20px;text-align:center;
  font-family:'Cormorant Garamond',serif;font-size:16px;color:rgba(255,255,255,.75);
}
.stats-footer span{color:var(--gold)}

/* ── FEATURES (страница 4 верх) ── */
.feat-grid-top{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:44px}
.feat-grid-bot{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:20px}
.feat-card{
  border:1px solid var(--border);border-radius:14px;
  padding:28px 24px;background:#fff;
  transition:transform .25s,box-shadow .25s,border-color .25s;
  text-align:center;
}
.feat-card:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(26,49,87,.08);border-color:rgba(201,151,58,.3)}
.feat-icon-circle{
  width:60px;height:60px;border-radius:50%;background:#F0F3F8;
  display:flex;align-items:center;justify-content:center;margin:0 auto 16px;
}
.feat-icon-circle svg{width:28px;height:28px}
.feat-title{font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:700;color:var(--navy);margin-bottom:6px}
.feat-gold{width:24px;height:2px;background:var(--gold);margin:0 auto 10px}
.feat-text{font-size:13.5px;color:var(--muted);line-height:1.6}

/* For whom strip (страница 4 низ) */
.for-whom{
  margin-top:52px;background:var(--navy);border-radius:16px;padding:36px 40px;
}
.for-whom-title{
  font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:700;color:#fff;
  margin-bottom:6px;
}
.for-whom-line{width:40px;height:2px;background:var(--gold);margin:0 0 28px}
.for-whom-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.for-card{
  background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);
  border-radius:12px;padding:20px 16px;text-align:center;
  transition:background .2s,border-color .2s;
}
.for-card:hover{background:rgba(255,255,255,.1);border-color:rgba(201,151,58,.3)}
.for-icon{
  width:48px;height:48px;border-radius:50%;background:rgba(201,151,58,.12);
  border:1px solid rgba(201,151,58,.25);
  display:flex;align-items:center;justify-content:center;margin:0 auto 12px;
}
.for-icon svg{width:22px;height:22px;stroke:var(--gold);fill:none;stroke-width:1.6}
.for-title{font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:700;color:#fff;margin-bottom:8px}
.for-text{font-size:12.5px;color:rgba(255,255,255,.5);line-height:1.55}

/* ── AUDIENCE (страница 2 верх и середина) ── */
.aud-block{
  border-radius:16px;overflow:hidden;
  border:1px solid rgba(201,151,58,.2);
  display:grid;grid-template-columns:1fr 1fr;
  margin-bottom:20px;
}
.aud-content{padding:40px 40px}
.aud-visual{
  position:relative;overflow:hidden;
  background:linear-gradient(160deg,var(--navy-dark),var(--navy));
  display:flex;align-items:center;justify-content:center;
}
.aud-visual-text{
  font-family:'Cormorant Garamond',serif;font-size:80px;font-weight:700;
  color:rgba(201,151,58,.12);letter-spacing:-4px;
}
.aud-block.dark{background:var(--navy)}
.aud-block.dark .aud-content{background:var(--navy)}
.aud-section-label{font-size:11px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;margin-bottom:10px}
.aud-section-label.gold{color:var(--gold)}
.aud-title{font-family:'Cormorant Garamond',serif;font-size:clamp(22px,3vw,30px);font-weight:700;margin-bottom:6px}
.aud-title.light{color:#fff}
.aud-title.dark-text{color:var(--navy)}
.aud-line{width:36px;height:2px;background:var(--gold);margin-bottom:20px}
.checklist{list-style:none;display:flex;flex-direction:column;gap:11px}
.checklist li{display:flex;align-items:flex-start;gap:10px;font-size:14px;line-height:1.55}
.checklist li.light{color:rgba(255,255,255,.8)}
.checklist li.dark-li{color:var(--text)}
.check-icon{
  width:18px;height:18px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;margin-top:1px;
}
.check-icon.gold-bg{background:var(--gold)}
.check-icon.navy-bg{background:var(--navy)}
.check-icon svg{width:9px;height:9px}

/* ── CTA (страница 2 низ) ── */
.cta-section{
  background:var(--navy);padding:80px 0;
}
.cta-inner{
  display:block;
  max-width:560px;
}
.cta-eyebrow{
  font-size:11px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;
  color:var(--gold);margin-bottom:14px;
}
.cta-h{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(28px,4vw,44px);font-weight:700;color:#fff;
  line-height:1.1;margin-bottom:14px;
}
.cta-text{font-size:15px;color:rgba(255,255,255,.6);line-height:1.7;margin-bottom:24px;max-width:420px}
.cta-contact{display:flex;align-items:center;gap:8px;margin-top:8px}
.cta-contact-icon{
  width:28px;height:28px;border-radius:6px;
  background:rgba(201,151,58,.15);border:1px solid rgba(201,151,58,.2);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.cta-contact-icon svg{width:13px;height:13px;stroke:var(--gold);fill:none;stroke-width:1.8}
.cta-contact-text{font-size:14px;color:rgba(255,255,255,.65)}

/* QR block */


/* ── FOOTER ── */
footer{
  background:var(--navy-dark);padding:24px 36px;
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;
